{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "astroway/tarot-daily",
	"title": "AstroWay: Daily Tarot",
	"category": "widgets",
	"description": "Single-card daily Tarot draw with interpretation.",
	"textdomain": "astroway",
	"icon": "image-flip-horizontal",
	"supports": {
		"html": false,
		"align": [ "center" ],
		"customClassName": true
	},
	"attributes": {
		"deck": { "type": "string", "default": "rider-waite", "enum": [ "rider-waite", "marseille", "lenormand" ] }
	},
	"editorScript": "astroway-blocks-editor"
}
